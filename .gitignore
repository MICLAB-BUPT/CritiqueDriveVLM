__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.venv/
venv/
env/

# uv
uv.lock

# Data & datasets (download from HuggingFace / nuScenes)
*.json
*.jsonl
*.parquet
*.csv
*.xlsx
data/
datasets/
stitched_output/

# Model weights / checkpoints / cached tensors
*.pt
*.pth
*.bin
*.safetensors
