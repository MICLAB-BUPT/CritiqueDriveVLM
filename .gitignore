checkpoints/
outputs/
lora/

# Inference / evaluation results
results/
results_reflexion/
score/
scored_results/
error_analysis_output/

# Logs
*.log
logs/
wandb/
swanlog/
.swanlab/
ray_tmp/

# OS / editor
.DS_Store
.idea/
.vscode/

